# Lemma (lemma.work, by Gappy AI) — the hackathon SDK.
# The app talks to the gigops pod over REST. Auth is handled by the Lemma CLI
# (`lemma auth login`), and the app auto-refreshes tokens via `lemma auth
# print-token`, so you do NOT set a token here.
#
# Setup:
#   uv tool install lemma-terminal      # installs the `lemma` CLI
#   lemma auth login                    # browser login (once)
#   lemma pod import ./lemma-pod --pod gigops   # if recreating the pod
LEMMA_API_URL=https://api.lemma.work
LEMMA_POD_ID=                            # the gigops pod id (lemma pod get gigops)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
