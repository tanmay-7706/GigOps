# Groq — powers the Triage Agent and Action Agent (required)
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override the model (default: llama-3.3-70b-versatile)
GROQ_MODEL=

# Lemma — observability layer. The triage workflow exports OpenTelemetry traces
# to Lemma when these are set; if unset, spans are logged to the console only
# (the app still works fully). LEMMA_OTLP_ENDPOINT is Lemma's OTLP/HTTP traces
# endpoint, e.g. https://otel.uselemma.ai/v1/traces
LEMMA_OTLP_ENDPOINT=
LEMMA_API_KEY=
LEMMA_PROJECT_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
