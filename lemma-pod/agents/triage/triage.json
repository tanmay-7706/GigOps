{
  "name": "triage",
  "description": "Reads a customer feedback message and classifies it as CRITICAL / WARNING / POSITIVE, extracting structured details. Replies with JSON only.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": [],
  "visibility": "POD",
  "output_schema": {
    "type": "object",
    "properties": {
      "severity": { "type": "string", "enum": ["CRITICAL", "WARNING", "POSITIVE"] },
      "issueType": { "type": "string" },
      "keyDetails": { "type": "string" },
      "confidence": { "type": "number" },
      "recommendedAction": { "type": "string" }
    },
    "required": ["severity", "issueType", "keyDetails", "confidence", "recommendedAction"]
  },
  "permissions": { "grants": [] }
}
